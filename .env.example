# Configuration de l'agent IA financier gamifié

# Configuration Flask
SECRET_KEY=votre-cle-secrete-tres-longue-et-complexe
FLASK_ENV=development
FLASK_DEBUG=True

# Configuration OpenAI pour l'agent IA
OPENAI_API_KEY=sk-votre-cle-openai-ici

# Configuration API externe (optionnelle)
API_KEY=votre-cle-api-externe

# Configuration base de données (optionnelle, SQLite par défaut)
DATABASE_URL=sqlite:///financial_agent.db

# Configuration serveur (production)
PORT=5000
HOST=0.0.0.0

# Configuration sécurité
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Configuration logs
LOG_LEVEL=INFO
LOG_FILE=app.log

# Configuration email (optionnelle pour notifications)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Configuration cache Redis (optionnelle)
REDIS_URL=redis://localhost:6379/0

# Configuration analytics (optionnelle)
GOOGLE_ANALYTICS_ID=GA-XXXXXX-X

# Configuration backup automatique
BACKUP_ENABLED=True
BACKUP_INTERVAL_HOURS=24